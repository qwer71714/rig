{
  "name": "app-store-crawler",
  "version": "1.1.0",
  "description": "App Store & Google Play Store Crawler with Electron + Next.js UI",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.electron.json && next build",
    "start": "npm run build && electron .",
    "install:pw": "npx playwright install chromium",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:crawl": "docker-compose run --rm crawler node dist-electron/services/crawlService.js"
  },
  "build": {
    "appId": "com.crawler.appstore",
    "productName": "App Store Crawler",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "output/",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/playwright/.local-browsers",
      "!node_modules/playwright-core/.local-browsers"
    ],
    "extraResources": [
      {
        "from": "scripts/postinstall.js",
        "to": "postinstall.js"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "App Store Crawler"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Development"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  },
  "keywords": [
    "crawler",
    "scraper",
    "app-store",
    "play-store",
    "electron",
    "playwright",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "google-play-scraper": "^9.1.1",
    "next": "^15.1.0",
    "playwright": "^1.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
