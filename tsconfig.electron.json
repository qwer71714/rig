{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["electron/**/*.ts", "src/scrapers/**/*.ts", "src/services/**/*.ts", "src/utils/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", "out", "src/app", "src/components"]
}
